{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "intake-result.json",
  "type": "object",
  "required": [
    "request_id",
    "normalized_text",
    "detected_entities",
    "detected_action_verbs",
    "intent_type",
    "confidence"
  ],
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string"
    },
    "normalized_text": {
      "type": "string",
      "minLength": 5
    },
    "detected_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entity",
          "type",
          "source_span"
        ],
        "additionalProperties": false,
        "properties": {
          "entity": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "source_span": {
            "type": "string"
          }
        }
      }
    },
    "detected_action_verbs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "intent_type": {
      "type": "string",
      "enum": [
        "package_repair",
        "package_review",
        "package_enhance",
        "parameter_query",
        "out_of_scope"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
