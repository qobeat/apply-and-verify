{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "issue line in issues.partN.jsonl",
  "type": "object",
  "required": [
    "issue_id",
    "iteration",
    "fingerprint",
    "owner_surface",
    "problem",
    "required_fix",
    "status",
    "source",
    "ts"
  ],
  "additionalProperties": false,
  "properties": {
    "issue_id": {
      "type": "string",
      "pattern": "^ISS-[0-9]{3,}$"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0
    },
    "fingerprint": {
      "type": "string"
    },
    "owner_surface": {
      "type": "string"
    },
    "problem": {
      "type": "string",
      "minLength": 10
    },
    "evidence": {
      "type": [
        "string",
        "null"
      ]
    },
    "required_fix": {
      "type": "string",
      "minLength": 10
    },
    "verify": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "deferred"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "user",
        "review",
        "verify_failure",
        "reflect"
      ]
    },
    "ts": {
      "type": "string"
    }
  }
}
