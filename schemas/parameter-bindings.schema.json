{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "parameter-bindings.json",
  "type": "object",
  "required": [
    "request_id",
    "bindings"
  ],
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string"
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "parameter_name",
          "required",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "parameter_name": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "bound_explicit",
              "bound_from_context",
              "defaulted",
              "derived",
              "ambiguous",
              "missing",
              "contradictory",
              "out_of_scope"
            ]
          },
          "value": {},
          "source": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
