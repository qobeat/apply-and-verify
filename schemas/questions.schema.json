{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "questions.json",
  "type": "object",
  "required": [
    "request_id",
    "questions"
  ],
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "parameter_name",
          "question_text"
        ],
        "additionalProperties": false,
        "properties": {
          "question_id": {
            "type": "string",
            "pattern": "^Q-[0-9]{3,}$"
          },
          "parameter_name": {
            "type": "string"
          },
          "question_text": {
            "type": "string",
            "minLength": 10
          },
          "expected_format": {
            "type": [
              "string",
              "null"
            ]
          },
          "why_needed": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
