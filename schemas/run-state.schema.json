{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "run-state.json",
  "type": "object",
  "required": [
    "run_id",
    "current_state",
    "iteration",
    "started_at",
    "max_iterations"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string"
    },
    "current_state": {
      "type": "string"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0
    },
    "started_at": {
      "type": "string"
    },
    "agent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "max_iterations": {
      "type": "integer",
      "minimum": 1
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "state",
          "event",
          "ts"
        ],
        "additionalProperties": false,
        "properties": {
          "state": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "ts": {
            "type": "string"
          }
        }
      }
    }
  }
}
